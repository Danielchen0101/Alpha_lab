# Dependencies
node_modules/
**/node_modules/

# Build outputs
build/
dist/
coverage/
.next/
frontend/build/

# Playwright / E2E test artifacts
frontend/test-results/
frontend/playwright-report/
frontend/.playwright/

# Cache
.cache/
**/.cache/
.eslintcache

# Secrets — NEVER commit real keys
.env
.env.local
.env.development
.env.production
.env.*
!.env.example

# Python
__pycache__/
**/__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/
**/.pytest_cache/

# Logs
*.log
backend/*.log
backend/logs/
frontend/*.log

# Temp / debug files
*.txt
!requirements.txt
!README.md
!CONTRIBUTING.md
!COMMIT_CONVENTION.md
!CHANGELOG.md
!LICENSE

# Backups — never commit backup directories or files
backups/
backup/
*.bak
*.backup
*.backup2
*_backup.*
*_old.*
*_temp.*
*_tmp.*
tests_backup/
old_backup_*/

# Runtime / databases
backend/instance/
*.db
backend/ai_provider_config.json
backend/alpaca_config.json
backend/finnhub_config.json
backend/market_data_config.json

# IDEs
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Claude / AI tooling
.claude/settings.local.json

# Memory / temp scripts
memory/*.py

# Runtime state files (auto-generated)
backend/auto_scan_configs.json
backend/pipeline_auto_configs.json
backend/pipeline_auto_history.json

# Debug dumps — never commit
backend/debug_manual_pipeline_result.json
backend/debug_auto_pipeline_result.json
