# === Alpaca Trading ===
ALPACA_API_KEY=YOUR_ALPACA_API_KEY
ALPACA_API_SECRET=YOUR_ALPACA_API_SECRET
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# === Alpaca Paper Trading ===
ALPACA_PAPER_API_KEY=YOUR_ALPACA_PAPER_API_KEY
ALPACA_PAPER_SECRET_KEY=YOUR_ALPACA_PAPER_SECRET_KEY

# === Alpaca Real Trading ===
ALPACA_REAL_API_KEY=YOUR_ALPACA_REAL_API_KEY
ALPACA_REAL_SECRET_KEY=YOUR_ALPACA_REAL_SECRET_KEY

# === Alpaca Market Data ===
ALPACA_MARKET_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_MARKET_DATA_FEED=iex

# === Finnhub (Market Data) ===
FINNHUB_API_KEY=YOUR_FINNHUB_API_KEY

# === AI Provider ===
AI_PROVIDER=DeepSeek
AI_API_KEY=YOUR_AI_API_KEY
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# === Flask ===
FLASK_ENV=development
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
DATABASE_URL=sqlite:///quant.db

# === Frontend ===
REACT_APP_API_BASE_URL=/api
REACT_APP_WS_BASE_URL=ws://localhost:8889

# === Dev ===
PORT=8889
DEBUG=true
