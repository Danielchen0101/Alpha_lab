# AlphaLab all-in-one deployment — safe example values only.
# For local split development, prefer backend/.env.example and
# frontend/.env.example in their respective directories.

# Backend authentication and persistence
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FERNET_KEY=generate-a-fernet-key
APP_SECRET_KEY=replace-with-a-long-random-secret
FRONTEND_ORIGIN=http://localhost:3000

# Optional bootstrap administrator
ALPHALAB_ADMIN_EMAIL=
ALPHALAB_ADMIN_PASSWORD=

# Runtime
PORT=8080
FLASK_ENV=production
FLASK_DEBUG=false
DEBUG_ENDPOINTS=false
PIPELINE_AUTO_FILE_FALLBACK=false

# Public React build-time configuration
REACT_APP_API_BASE_URL=/api
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-public-anon-key
REACT_APP_TURNSTILE_SITE_KEY=

# Alpaca, market-data, AI, and notification credentials are normally saved
# per user from Settings > Connections. Do not place browser-side secrets here.
