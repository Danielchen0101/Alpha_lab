# === User API Keys ===
# Alpaca, Finnhub, and AI Provider API keys are configured per-user
# via the Settings / Configuration page and stored in the database.
# Do NOT set user API keys in this file.

# === Auth ===
ALPHALAB_ADMIN_EMAIL=admin@example.com
ALPHALAB_ADMIN_PASSWORD=CHANGE_ME
APP_SECRET_KEY=CHANGE_ME

# === Flask ===
FLASK_ENV=development
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
DATABASE_URL=sqlite:///quant.db

# === Frontend ===
REACT_APP_API_BASE_URL=/api
REACT_APP_WS_BASE_URL=ws://localhost:8889

# === Dev ===
PORT=8889
DEBUG=true
