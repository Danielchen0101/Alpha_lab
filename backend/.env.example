# AlphaLab backend — safe example values only.
# Copy this file to backend/.env and replace every required placeholder.

# Supabase server credentials. The service-role key must remain server-side.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Fernet encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# IMPORTANT: Must match the FERNET_KEY used in production (Render), otherwise
# encrypted API keys saved online cannot be decrypted locally and vice versa.
FERNET_KEY=

# Flask session signing. Generate a long random value for every deployment.
APP_SECRET_KEY=replace-with-a-long-random-secret

# Frontend origin for CORS (backend reads FRONTEND_ORIGIN, not CORS_ORIGINS)
FRONTEND_ORIGIN=http://localhost:3000

# Optional bootstrap administrator. Leave blank when not required.
ALPHALAB_ADMIN_EMAIL=
ALPHALAB_ADMIN_PASSWORD=

# Runtime flags. Durable Supabase storage is recommended in production.
FLASK_ENV=development
FLASK_DEBUG=false
DEBUG_ENDPOINTS=false
PIPELINE_AUTO_FILE_FALLBACK=false

# User API keys (Alpaca, Finnhub, AI) are configured per-user
# via the Settings / Configuration page and stored in Supabase.
# Do NOT set user API keys in this file.
