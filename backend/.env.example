# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Fernet encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# IMPORTANT: Must match the FERNET_KEY used in production (Render), otherwise
# encrypted API keys saved online cannot be decrypted locally and vice versa.
FERNET_KEY=

# Flask
APP_SECRET_KEY=dev-secret-change-me

# Frontend origin for CORS (backend reads FRONTEND_ORIGIN, not CORS_ORIGINS)
FRONTEND_ORIGIN=http://localhost:3000

# Optional admin
ALPHALAB_ADMIN_EMAIL=
ALPHALAB_ADMIN_PASSWORD=

# User API keys (Alpaca, Finnhub, AI) are configured per-user
# via the Settings / Configuration page and stored in Supabase.
# Do NOT set user API keys in this file.
