                        </div>
                      </div>
                    </div>
                  </div>
                );
              })()}
            </Card>
          )}
          
          {/* Experiment Ranking */}
          {sessionHistory.length > 0 && (
            <Card 
              title="Experiment Ranking" 
              style={{ marginTop: '24px', backgroundColor: '#fff7e6' }}
              extra={
                <Text type="secondary" style={{ fontSize: '12px' }}>
                  Sorted by Return %
                </Text>
              }
            >
              {(() => {
                // 计算 ranking
                const rankedSessions = [...sessionHistory]
                  .sort((a, b) => b.returnPct - a.returnPct) // 按 returnPct 降序
                  .slice(0, 5); // 只显示前5名
                
                // 策略名称映射
                const strategyNameMap: Record<string, string> = {
                  'DEMO_STRATEGY': 'Demo',
                  'RANDOM_SIGNAL': 'Random',
                  'SMA_STRATEGY': 'SMA',
                  'MA_CROSSOVER': 'MA Cross',
                };
                
                // 获取 preset 名称
                const getPresetName = (session: SessionHistoryItem): string => {
                  if (session.strategyMode === 'MA_CROSSOVER' && session.shortMaPeriod !== undefined && session.longMaPeriod !== undefined) {
                    if (session.shortMaPeriod === 5 && session.longMaPeriod === 10) return 'Fast (5/10)';
                    if (session.shortMaPeriod === 10 && session.longMaPeriod === 20) return 'Medium (10/20)';
                    if (session.shortMaPeriod === 20 && session.longMaPeriod === 50) return 'Slow (20/50)';
                    return `Custom (${session.shortMaPeriod}/${session.longMaPeriod})`;
                  }
                  return strategyNameMap[session.strategyMode] || session.strategyMode;
                };
                
                return (
                  <div>
                    <Table
                      dataSource={rankedSessions.map((session, index) => ({
                        key: session.id,
                        rank: index + 1,
                        ...session,
                        presetName: getPresetName(session),
                        totalCost: session.totalSlippage + session.totalCommission,
                      }))}
                      pagination={false}
                      size="small"
                      columns={[
                        {
                          title: 'Rank',
                          dataIndex: 'rank',
                          key: 'rank',
                          width: 60,
                          render: (rank: number) => (
                            <div style={{ 
                              display: 'flex', 
                              alignItems: 'center',
                              justifyContent: 'center'
                            }}>
                              {rank === 1 && (
                                <span style={{ 
                                  color: '#faad14', 
                                  fontSize: '16px',
                                  marginRight: '4px'
                                }}>🥇</span>
                              )}
                              {rank === 2 && (
                                <span style={{ 
                                  color: '#d9d9d9', 
                                  fontSize: '16px',
                                  marginRight: '4px'
                                }}>🥈</span>
                              )}
                              {rank === 3 && (
                                <span style={{ 
                                  color: '#ad8b00', 
                                  fontSize: '16px',
                                  marginRight: '4px'
                                }}>🥉</span>
                              )}
                              {rank > 3 && (
                                <span style={{ 
                                  fontWeight: 'bold',
                                  color: rank <= 5 ? '#1890ff' : '#8c8c8c'
                                }}>
                                  #{rank}
                                </span>
                              )}
                            </div>
                          ),
                        },
                        {
                          title: 'Strategy / Preset',
                          dataIndex: 'presetName',
                          key: 'presetName',
                          width: 120,
                          render: (presetName: string, record: any) => (
                            <div>
                              <div style={{ fontWeight: '500' }}>{presetName}</div>
                              <div style={{ fontSize: '11px', color: '#8c8c8c' }}>
                                {record.symbol}
                              </div>
                            </div>
                          ),
                        },
                        {
                          title: 'Return',
                          dataIndex: 'returnPct',
                          key: 'returnPct',
                          width: 90,
                          align: 'right' as const,
                          render: (value: number) => (
                            <Text style={{ 
                              color: value >= 0 ? '#3f8600' : '#cf1322',
                              fontWeight: 'bold'
                            }}>
                              {value >= 0 ? '+' : ''}{value.toFixed(2)}%
                            </Text>
                          ),
                        },
                        {
                          title: 'Trades',
                          dataIndex: 'totalTrades',
                          key: 'totalTrades',
                          width: 70,
                          align: 'right' as const,
                          render: (value: number) => (
                            <Text>{value}</Text>
                          ),
                        },
                        {
                          title: 'Cost',
                          dataIndex: 'totalCost',
                          key: 'totalCost',
                          width: 80,
                          align: 'right' as const,
                          render: (value: number) => (
                            <Text type="secondary">${value.toFixed(2)}</Text>
                          ),
                        },
                        {
                          title: 'Time',
                          dataIndex: 'durationMinutes',
                          key: 'durationMinutes',
                          width: 70,
                          align: 'right' as const,
                          render: (minutes: number) => (
                            <Text type="secondary" style={{ fontSize: '11px' }}>
                              {minutes}m
                            </Text>
                          ),
                        },
                      ]}
                    />
                    
                    {/* Ranking Insights */}
                    {rankedSessions.length > 0 && (
                      <div style={{ 
                        marginTop: '12px', 
                        padding: '8px 12px', 
                        backgroundColor: '#f6ffed',
                        borderRadius: '4px',
                        fontSize: '12px'
                      }}>
                        <div style={{ display: 'flex', justifyContent: 'space-between' }}>
                          <div>
                            <Text type="secondary">
                              <strong>Top Performer:</strong> {getPresetName(rankedSessions[0])} on {rankedSessions[0].symbol}
                            </Text>
                          </div>
                          <div>
                            <Text style={{ 
                              color: rankedSessions[0].returnPct >= 0 ? '#3f8600' : '#cf1322',
                              fontWeight: 'bold'
                            }}>
                              {rankedSessions[0].returnPct >= 0 ? '+' : ''}{rankedSessions[0].returnPct.toFixed(2)}%
                            </Text>
                          </div>
                        </div>
                      </div>
                    )}
                  </div>
                );
              })()}
            </Card>
          )}
          
          {/* Session History */}