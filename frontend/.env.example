# AlphaLab web application — safe example values only.
# Copy this file to frontend/.env and replace the placeholders.

# Backend API base. The CRA development proxy uses /api locally.
# For a separately hosted frontend, use the public backend URL ending in /api.
REACT_APP_API_BASE_URL=/api

# Supabase public browser credentials. Never put a service-role key here.
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-public-anon-key

# Product metadata.
REACT_APP_ENV=development
REACT_APP_VERSION=3.0.0
REACT_APP_NAME=AlphaLab

# Optional Cloudflare Turnstile site key for sign-in and registration.
# Production registration is unavailable when this value is missing.
REACT_APP_TURNSTILE_SITE_KEY=

# Compatibility alias used by one legacy market-data client. Prefer
# REACT_APP_API_BASE_URL for new code.
REACT_APP_API_URL=/api
