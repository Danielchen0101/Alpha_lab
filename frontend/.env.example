# React前端环境配置模板
# 复制此文件为 .env 并根据需要修改

# API配置 — 后端 API 基础路径
# 本地开发（使用 package.json proxy）：保持默认 /api
# Cloudflare Pages 部署时设为：https://your-render-service.onrender.com/api
REACT_APP_API_BASE_URL=/api

# 应用配置
REACT_APP_ENV=development
REACT_APP_VERSION=1.0.0
REACT_APP_NAME=QuantPlatform

# 功能开关
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_DEBUG=true

# 第三方服务（未来扩展）
# REACT_APP_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
# REACT_APP_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ============================================
# Broker 配置
# ============================================

# Broker 模式：LOCAL 或 ALPACA_PAPER
REACT_APP_BROKER_MODE=LOCAL

# 注意：Alpaca API 密钥现在配置在后端，前端不再直接访问 Alpaca API
# 后端代理接口：/api/broker/account, /api/broker/positions, /api/broker/orders

# ============================================
# 环境文件说明：
# 1. .env - 默认环境变量（所有环境）
# 2. .env.development - 开发环境变量
# 3. .env.production - 生产环境变量
# 4. .env.local - 本地覆盖（不提交到版本控制）
# ============================================