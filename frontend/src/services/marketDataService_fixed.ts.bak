export const getStockHistory = async (
  symbol: string, 
  timeframe: string = '1M'
): Promise<HistoricalDataResponse> => {
  try {
    const config = TIMEFRAMES[timeframe] || TIMEFRAMES['1M'];
    
    const response = await api.get(`/market/history/${symbol}`, {
      params: {
        interval: config.interval,
        range: config.range,
      },
    });
    
    if (response.data) {
      const data = response.data;
      
      // 检查是否有错误
      if (data.error) {
        throw new Error(`Finnhub API错误: ${data.error}`);
      }
      
      return {
        ...data,
        symbol,
        interval: config.interval,
        range: config.range,
        dataSource: data.dataSource || data.source || 'Finnhub',
        count: data.count || (data.data ? data.data.length : 0),
      } as HistoricalDataResponse;
    } else {
      throw new Error('Finnhub返回空数据');
    }
    
  } catch (error) {
    console.error(`获取 ${symbol} 历史数据失败:`, error);
    throw error;
  }
};