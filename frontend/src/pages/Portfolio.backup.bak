    try {
      console.log(`[DEBUG] 开始获取 ${symbol} 新闻`);
      
      // 调用新的新闻接口
      const response = await api.get(`/market/news/${symbol}`);
      
      console.log(`[DEBUG] ${symbol} 新闻响应状态:`, response.status);
