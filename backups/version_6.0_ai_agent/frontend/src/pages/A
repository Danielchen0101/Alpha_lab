import React, { useState, useEffect } from 'react';
import { Card, Typography, Space, Statistic, Row, Col, Button, Tag, Alert, Divider, Table, Form, Switch, Select, message, Modal, Progress } from 'antd';
import { RobotOutlined, PlayCircleOutlined, CheckCircleOutlined, PauseCircleOutlined, LoadingOutlined, CheckOutlined, CloseOutlined } from '@ant-design/icons';
import aiTradingService, { AIDecision, AIRiskCheck, AIHistoryEntry } from '../services/aiTradingService';

const { Title, Text } = Typography;
const { Option } = Select;

const AITrading: React.FC = () => {
  const [form] = Form.useForm();
  const [loading, setLoading] = useState({ analyze: false, execute: false });
  const [aiStatus, setAiStatus] = useState({
    auto_mode: false,
    paper_only: true,
    human_confirm_required: true,
    allowed_symbols: ['AAPL', 'MSFT', 'NVDA', 'GOOGL', 'AMZN'],
    today_order_count: 0,
    last_analysis_time: null as string | null,
    last_execution_time: null as string | null,
    ai_status: 'idle'
  });
  const [accountSnapshot, setAccountSnapshot] = useState({
    cash: 0, equity: 0, buyingPower: 0, portfolioValue: 0, positionsCount: 0, openOrdersCount: 0
  });
  const [aiDecision, setAiDecision] = useState<AIDecision | null>(null);
  const [riskChecks, setRiskChecks] = useState<AIRiskCheck | null>(null);
  const [currentHistoryId, setCurrentHistoryId] = useState<number>(-1);
  const [aiHistory, setAiHistory] = useState<AIHistoryEntry[]>([]);
  const [confirmModalVisible, setConfirmModalVisible] = useState(false);

  useEffect(() => { loadInitialData(); }, []);

  const loadInitialData = async () => {
    try {
      const [statusResponse, snapshot, historyResponse] = await Promise.all([
        aiTradingService.getStatus(),
        aiTradingService.getAccountSnapshot(),
        aiTradingService.getHistory(20)
      ]);
      
      if (statusResponse.success) setAiStatus(statusResponse.state);
      setAccountSnapshot(snapshot);
      if (historyResponse.success) setAiHistory(historyResponse.history);
    } catch (error) {
      console.error('Failed to load initial data:', error);
    }
  };

  const handleAnalyze = async () => {
    const values = await form.validateFields();
    setLoading(prev => ({ ...prev, analyze: true }));
    
    try {
      const response = await aiTradingService.previewTrade(values.symbol);
      
      if (response.success) {
        setAiDecision(response.decision);
        setRiskChecks(response.risk_checks);
        setCurrentHistoryId(response.history_id);
        
        const [statusResponse, historyResponse] = await Promise.all([
          aiTradingService.getStatus(),
          aiTradingService.getHistory(20)
        ]);
        
        if (statusResponse.success) setAiStatus(statusResponse.state);
        if (historyResponse.success) setAiHistory(historyResponse.history);
        
        message.success('AI analysis completed');
      } else {
        message.error(`Analysis failed: ${response.validation.message}`);
      }
    } catch (error: any) {
      message.error(`Analysis error: ${error.message}`);
    } finally {
      setLoading(prev => ({ ...prev, analyze: false }));
    }
  };

  const handleExecute = async () => {
    if (currentHistoryId === -1 || !aiDecision) {
      message.error('No valid AI decision to execute');
      return;
    }
    
    if (aiStatus.human_confirm_required) {
      setConfirmModalVisible(true);
      return;
    }
    
    await executeTrade();
  };

  const executeTrade = async () => {
    setLoading(prev => ({ ...prev, execute: true }));
    
    try {
      const response = await aiTradingService.executeTrade(
        currentHistoryId, 
        aiStatus.human_confirm_required
      );
      
      if (response.success) {
        message.success('Trade executed successfully');
        
        const [statusResponse, snapshot, historyResponse] = await Promise.all([
          aiTradingService.getStatus(),
          aiTradingService.getAccountSnapshot(),
          aiTradingService.getHistory(20)
        ]);
        
        if (statusResponse.success) setAiStatus(statusResponse.state);
        setAccountSnapshot(snapshot);
        if (historyResponse.success) setAiHistory(historyResponse.history);
      } else {
        message.error(`Execution failed: ${response.error}`);
      }
    } catch (error: any) {
      message.error(`Execution error: ${error.message}`);
    } finally {
      setLoading(prev => ({ ...prev, execute: false }));
      setConfirmModalVisible(false);
    }
  };

  const handleToggleAutoMode = async () => {
    try {
      const response = await aiTradingService.toggleAutoMode(!aiStatus.auto_mode);
      if (response.success) {
        setAiStatus(prev => ({ ...prev, auto_mode: response.auto_mode }));
        message.success(`Auto mode ${response.auto_mode ? 'enabled' : 'disabled'}`);
      }
    } catch (error: any) {
      message.error(`Failed to toggle auto mode: ${error.message}`);
    }
  };

  const formatTime = (time: string | null) => time ? new Date(time).toLocaleString() : 'Never';
  const getStatusColor = (status: string) => {
    switch (status) {
      case 'idle': return 'default';
      case 'analyzing': return 'processing';
      case 'ready': return 'success';
      case 'executed': return 'success';
      case 'error': return 'error';
      default: return 'default';
    }
  };

  const getActionColor = (action: string) => {
    switch (action) {
      case 'BUY': return 'green';
      case 'SELL': return 'red';
      case 'HOLD': return 'blue';
      case 'CANCEL': return 'orange';
      default: return 'default';
    }
  };

  const historyColumns = [
    { title: 'Time', dataIndex: 'timestamp', key: 'timestamp', render: (text: string) => new Date(text).toLocaleTimeString() },
    { title: 'Symbol', dataIndex: 'symbol', key: 'symbol' },
    { title: 'Action', dataIndex: 'action', key: 'action', render: (action: string) => <Tag color={getActionColor(action)}>{action}</Tag> },
    { title: 'Qty', dataIndex: 'qty', key: 'qty' },
    { title: 'Confidence', dataIndex: 'confidence', key: 'confidence', render: (confidence: number) => <Progress percent={Math.round(confidence * 100)} size="small" /> },
    { title: 'Risk', dataIndex: 'executable', key: 'executable', render: (executable: boolean) => (
      <Tag color={executable ? 'green' : 'red'}>{executable ? 'Passed' : 'Blocked'}</Tag>
    )},
    { title: 'Executed', dataIndex: 'executed', key: 'executed', render: (executed: boolean) => (
      executed ? <CheckOutlined style={{ color: '#52c41a' }} /> : <CloseOutlined style={{ color: '#ff4d4f' }} />
    )},
  ];

  return (
    <div>
      <Title level={2}><RobotOutlined style={{ marginRight: '12px' }} />AI Trading</Title>
      <Text type="secondary">DeepSeek-powered trading decisions with Alpaca Paper Trading</Text>
      
      <Divider />
      
      {/* AI Status */}
      <div style={{ marginBottom: 24 }}>
        <Title level={4}>AI Status</Title>
        <Row gutter={[16, 16]}>
          <Col xs={24} sm={12} lg={6}>
            <Card size="small">
              <Statistic title="Provider" value="DeepSeek" />
            </Card>
          </Col>
          <Col xs={24} sm={12} lg={6}>
            <Card size="small">
              <Statistic title="Trading Mode" value={aiStatus.auto_mode ? 'Auto' : 'Preview'} />
            </Card>
          </Col>
          <Col xs={24} sm={12} lg={6}>
            <Card size="small">
              <Statistic title="Auto Trading" value={aiStatus.auto_mode ? 'ON' : 'OFF'} />
            </Card>
          </Col>
          <Col xs={24} sm={12} lg={6}>
            <Card size="small">
              <Statistic title="Paper Only" value={aiStatus.paper_only ? 'ON' : 'OFF'} />
            </Card>
          </Col>
        </Row>
        <Row gutter={[16, 16]} style={{ marginTop: 16 }}>
          <Col xs={24} sm={12} lg={6}>
            <Card size="small"><Text strong>Last Analysis:</Text><Text type="secondary" style={{ display: 'block' }}>{formatTime(aiStatus.last_analysis_time)}</Text></Card>
          </Col>
          <Col xs={24} sm={12} lg={6}>
            <Card size="small"><Text strong>Last Execution:</Text><Text type="secondary" style={{ display: 'block' }}>{formatTime(aiStatus.last_execution_time)}</Text></Card>
          </Col>
          <Col xs={24} sm={12} lg={6}>
            <Card size="small"><Text strong>Last Decision:</Text><Text type="secondary" style={{ display: 'block' }}>{aiDecision ? `${aiDecision.action} ${aiDecision.symbol}` : 'None'}</Text></Card>
          </Col>
          <Col xs={24} sm={12} lg={6}>
            <Card size="small"><Text strong>AI Status:</Text><Tag color={getStatusColor(aiStatus.ai_status)} style={{ marginTop: 4 }}>{aiStatus.ai_status.toUpperCase()}</Tag></Card>
          </Col>
        </Row>
      </div>
      
      {/* Account Snapshot */}
      <div style={{ marginBottom: 24 }}>
        <Title level={4}>Account Snapshot</Title>
        <Row gutter={[16, 16]}>
          <Col xs={24} sm={12} lg={4}>
            <Card size="small"><Statistic title="Cash" value={accountSnapshot.cash} prefix="$" precision={2} /></Card>
          </Col>
          <Col xs={24} sm={12} lg={4}>
            <Card size="small"><Statistic title="Equity" value={accountSnapshot.equity} prefix="$" precision={2} /></Card>
          </Col>
          <Col xs={24} sm={12} lg={4}>
            <Card size="small"><Statistic title="Buying Power" value={accountSnapshot.buyingPower} prefix="$" precision={2} /></Card>
          </Col>
          <Col xs={24} sm={12} lg={4}>
            <Card size="small"><Statistic title="Portfolio Value" value={accountSnapshot.portfolioValue} prefix="$" precision={2} /></Card>
          </Col>
          <Col xs={24} sm={12} lg={4}>
            <Card size="small"><Statistic title="Positions" value={accountSnapshot.positionsCount} /></Card>
          </Col>
          <Col xs={24} sm={12} lg={4}>
            <Card size="small"><Statistic title="Open Orders" value={accountSnapshot.openOrdersCount} /></Card>
          </Col>
        </Row>
      </div>
      
      {/* AI Settings */}
      <div style={{ marginBottom: 24 }}>
        <Title level={4}>AI Settings</Title>
        <Card>
          <Form form={form} layout="vertical" initialValues={{ symbol: 'AAPL', humanConfirm: true, allowAuto: false }}>
            <Row gutter={[16, 16]}>
              <Col xs={24} sm={12} lg={6}>
                <Form.Item label="Symbol" name="symbol" rules={[{ required: true }]}>
                  <Select>
                    {aiStatus.allowed_symbols.map(symbol => (
                      <Option key={symbol} value={symbol}>{symbol}</Option>
                    ))}
                  </Select>
                </Form.Item>
              </Col>
              <Col xs={24} sm={12} lg={6}>
                <Form.Item label="Human Confirm Required" name="humanConfirm" valuePropName="checked">
                  <Switch />
                </Form.Item>
              </Col>
              <Col xs={24} sm={12} lg={6}>
                <Form.Item label="Allow Auto Mode" name="allowAuto" valuePropName="checked">
                  <Switch />
                </Form.Item>
              </Col>
              <Col xs={24} sm={12} lg={6}>
                <Button type="dashed" onClick={handleToggleAutoMode} block>
                  {aiStatus.auto_mode ? 'Disable Auto Mode' : 'Enable Auto Mode'}
                </Button>
              </Col>
            </Row>
          </Form>
        </Card>
      </div>
      
      {/* AI Analysis & Execution */}
      <div style={{ marginBottom: 24 }}>
        <Title level={4}>AI Analysis & Execution</Title>
        <Card>
          <Space size="large">
            <Button type="primary" icon={loading.analyze ? <LoadingOutlined /> : <PlayCircleOutlined />} size="large" onClick={handleAnalyze} loading={loading.analyze}>
              Analyze
            </Button>
            <Button type="default" icon={loading.execute ? <LoadingOutlined /> : <CheckCircleOutlined />} size="large" onClick={handleExecute} loading={loading.execute} disabled={!aiDecision || !riskChecks?.executable}>
              Execute Trade
            </Button>
            <Button type="dashed" icon={<PauseCircleOutlined />} size="large" onClick={handleToggleAutoMode}>
              {aiStatus.auto_mode ? 'Disable Auto' : 'Enable Auto'}
            </Button>
          </Space>
        </Card>
      </div>
      
      {/* AI Decision Result */}
      {aiDecision && (
        <div style={{ marginBottom: 24 }}>
          <Title level={4}>AI Decision Result</Title>
          <Card>
            <Row gutter={[16, 16]}>
              <Col span={24}>
                <Alert message={`Decision: ${aiDecision.action} ${aiDecision.symbol} x${aiDecision.qty}`} type="info" showIcon />
              </Col>
              <Col span={24}>
                <Text strong>Reason: </Text>
                <Text>{aiDecision.reason || 'No reason provided'}</Text>
              </Col>
              <Col span={24}>
                <Text strong>Confidence: </Text>
                <Progress percent={Math.round((aiDecision.confidence || 0) * 100)} style={{ width: 200, display: 'inline-block', marginLeft: 8 }} />
              </Col>
            </Row>
          </Card>
        </div>
      )}
      
      {/* Risk Check Results */}
      {riskChecks && (
        <div style={{ marginBottom: 24 }}>
          <Title level={4}>Risk Check Results</Title>
          <Card>
            <Row gutter={[16, 16]}>
              <Col span={24}>
                <Alert message={`Risk checks: ${riskChecks.passed.length} passed, ${riskChecks.blocked.length} blocked`} type={riskChecks.executable ? 'success' : 'warning'} showIcon />
              </Col>
              {riskChecks.blocked.length > 0 && (
                <Col span={24}>
                  <Text strong>Blocked checks:</Text>
                  <ul>
                    {riskChecks.blocked.map(([check, reason], index) => (
                      <li key={index}><Text type="danger">{check}: {reason}</Text></li>
                    ))}
                  </ul>
                </Col>
              )}
            </Row>
          </Card>
        </div>
      )}
      
      {/* AI History */}
      <div style={{ marginBottom: 24 }}>
        <Title level={4}>AI Decision History</Title>
        <Card>
          <Table columns={historyColumns} dataSource={aiHistory} rowKey="timestamp" size="small" />
        </Card>
      </div>
      
      {/* Confirmation Modal */}
      <Modal
        title="Confirm Trade Execution"
        open={confirmModalVisible}
        onOk={executeTrade}
        onCancel={() => setConfirmModalVisible(false)}
        okText="Execute Trade"
        cancelText="Cancel"
      >
        <p>Are you sure you want to execute this trade?</p>
        {aiDecision && (
          <Alert
            message={`${aiDecision.action} ${aiDecision.symbol} x${aiDecision.qty}`}
            description={aiDecision.reason}
            type="info"
            showIcon
          />
        )}
      </Modal>
      
      <Alert
        message="AI Trading is currently in preview mode. All trades require human confirmation and are paper-only."
        type="warning"
        showIcon
      />
    </div>
  );
};

export default AITrading;